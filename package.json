{
  "name": "runly-cli",
  "version": "0.1.0",
  "description": "Workflow CLI for structured agentic software engineering with RunlyAI",
  "type": "module",
  "main": "src/main.ts",
  "bin": {
    "runly": "src/main.ts"
  },
  "files": [
    "src",
    "templates",
    "AGENTS.md"
  ],
  "scripts": {
    "dev": "bun run src/main.ts",
