{
  "name": "@runlyai/cli",
  "version": "0.3.0",
  "description": "Local CLI for RunlyAI Learn — workflow scaffolding for agentic software engineering.",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "runly": "dist/main.js",
    "runly-cli": "dist/main.js"
  },
  "files": [
    "dist",
    "templates",
    "AGENTS.md"
  ],
  "scripts": {
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\"",
    "build": "pnpm clean && tsc -p tsconfig.json",
    "dev": "tsx src/main.ts",
    "prepack": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "runly",
    "ai",
    "cli",
    "workflow",
    "agents"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.17.0",
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "commander": "^14.0.3",
    "tar": "^7.4.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.0",
    "tsx": "^4.20.5",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
