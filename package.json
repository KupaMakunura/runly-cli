    "cli",
    "workflow",
    "agents"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.17.0",
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "commander": "^14.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
